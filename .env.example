# Copy this file to .env for local overrides. Keep every committed value empty.

# Application — API_BASE_URL is server-only; never prefix provider settings with NEXT_PUBLIC_.
APP_ENV=
API_BASE_URL=
DATABASE_URL=
REDIS_URL=

# Local PostgreSQL service
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=

# LLM — server-side only. Development model policy accepts only openrouter/free.
LLM_PROVIDER=
OPENROUTER_BASE_URL=
OPENROUTER_MODEL=
OPENROUTER_API_KEY=
LLM_MAX_ATTEMPTS=

# Market data
FINNHUB_API_KEY=
FMP_API_KEY=
SEC_USER_AGENT=
