  "claims": [
    {
      "claim_id": "CLM-001",
      "type": "fact",
      "text": {
        "zh_CN": "公司2025财年营业收入45.2亿元，同比增长20.2%。",
        "en_AU": "The company reported FY2025 revenue of CNY 4.52 billion, up 20.2% year on year."
      },
      "source_ids": [
        "SRC-001"
      ],
      "metric_ids": [
        "MET-001",
        "MET-002",
        "MET-003"
      ],
      "confidence": 0.98,
      "review_status": "verified"
    },
    {
      "claim_id": "CLM-002",
      "type": "fact",
      "text": {
        "zh_CN": "2026年3月发布的产业指导意见（虚构）提出支持智能制造装备国产替代。",
        "en_AU": "Industry guidance issued in March 2026 (fictional) supports domestic substitution in intelligent manufacturing equipment."
      },
      "source_ids": [
        "SRC-003"
      ],
      "confidence": 0.95,
      "review_status": "verified"
    },
    {
      "claim_id": "CLM-003",
      "type": "inference",
      "text": {
        "zh_CN": "在政策支持和收入高增长的背景下，公司有望继续扩大国内市场份额。",
        "en_AU": "Given policy support and strong revenue growth, the company is likely to keep gaining domestic market share."
      },
      "based_on_claim_ids": [
        "CLM-001",
        "CLM-002"
      ],
      "confidence": 0.7,
      "review_status": "verified"
    },
    {
      "claim_id": "CLM-004",
      "type": "opinion",
      "text": {
        "zh_CN": "我们认为公司是行业国产替代的主要受益者之一，给予“增持”评级。",
        "en_AU": "We view the company as a key beneficiary of domestic substitution and assign an Accumulate rating."
      },
      "based_on_claim_ids": [
        "CLM-003"
      ],
      "confidence": 0.6,
      "review_status": "verified"
    },
    {
      "claim_id": "CLM-005",
      "type": "inference",
      "text": {
        "zh_CN": "行业产能扩张较快，若下游资本开支放缓，公司增速可能明显低于我们的预测。",
        "en_AU": "Industry capacity is expanding quickly; if downstream capital expenditure slows, growth could fall well short of our forecast."
      },
      "source_ids": [
        "SRC-004"
      ],
      "confidence": 0.6,
      "review_status": "verified",
      "is_counterevidence": true
    },
    {
      "claim_id": "CLM-006",
      "type": "inference",
      "text": {
        "zh_CN": "同业价格竞争加剧可能压缩毛利率。",
        "en_AU": "Intensifying price competition among peers may compress gross margin."
      },
      "source_ids": [
        "SRC-004"
      ],
      "confidence": 0.65,
      "review_status": "verified"
    },
    {
      "claim_id": "CLM-007",
      "type": "inference",
      "text": {
        "zh_CN": "产业政策方向若调整，相关补贴和订单支持可能减弱。",
        "en_AU": "A shift in industrial policy direction could reduce subsidy and order support."
      },
      "based_on_claim_ids": [
        "CLM-002"
      ],
      "confidence": 0.5,
      "review_status": "verified"
    },
    {
      "claim_id": "CLM-008",
      "type": "fact",
      "text": {
        "zh_CN": "公司前五大客户收入占比约42%（2025年年报，虚构数据）。",
        "en_AU": "The top five customers account for roughly 42% of revenue (FY2025 annual report, fictional data)."
      },
      "source_ids": [
        "SRC-001"
      ],
      "confidence": 0.95,
      "review_status": "verified"
    },
    {
      "claim_id": "CLM-009",
      "type": "inference",
      "text": {
        "zh_CN": "基准情景假设2026-2028年收入复合增速15%，对应DCF每股价值34.0元。",
        "en_AU": "Our base case assumes a 15% revenue CAGR over 2026-2028, implying a DCF value of CNY 34.0 per share."
      },
      "metric_ids": [
        "MET-006"
      ],
      "confidence": 0.6,
      "review_status": "verified"
    },
    {
      "claim_id": "CLM-010",
      "type": "inference",
      "text": {
        "zh_CN": "WACC取9.5%，反映A股工业自动化板块的股权成本与公司较低的杠杆水平。",
        "en_AU": "We apply a 9.5% WACC, reflecting A-share industrial-automation equity costs and the company's low leverage."
      },
      "source_ids": [
        "SRC-004"
      ],
      "confidence": 0.6,
      "review_status": "verified"
    },
    {
      "claim_id": "CLM-011",
      "type": "inference",
      "text": {
        "zh_CN": "公司预计于2026年四季度发布新一代控制系统，若如期落地有望带来新订单。",
        "en_AU": "The company plans to launch its next-generation control system in Q4 2026; an on-time launch could drive new orders."
      },
      "source_ids": [
        "SRC-001"
      ],
      "confidence": 0.55,
