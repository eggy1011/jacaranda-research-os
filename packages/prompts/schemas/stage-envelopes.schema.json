{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jacaranda.example/schemas/stage-envelopes.schema.json",
  "title": "Jacaranda prompt-stage I/O envelopes",
  "description": "Machine-readable output schemas for every executable prompt stage (S1-S6). S7's output schema is slide-deck.schema.json itself. Claim/catalyst/risk fragments $ref the research-package schema so envelope and package definitions cannot drift. Keys beginning with underscore are ignorable annotations. See registry.json for task_name bindings. Version 0.1.0.",
  "$defs": {
    "claimId": { "type": "string", "pattern": "^CLM-[0-9]{3}$" },
    "metricId": { "type": "string", "pattern": "^MET-[0-9]{3}$" },
    "sourceId": { "type": "string", "pattern": "^SRC-[0-9]{3}$" },
    "assumptionId": { "type": "string", "pattern": "^ASM-[0-9]{3}$" },
    "claimFragment": { "$ref": "https://jacaranda.example/schemas/research-package.schema.json#/properties/claims/items" },
    "annotations": { "patternProperties": { "^_": {} } },

    "requestedCalculation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["request_id", "calculation_type", "input_metric_ids", "output_expectation", "needed_for"],
      "properties": {
        "request_id": { "type": "string", "pattern": "^CALC-[0-9]{3}$" },
        "calculation_type": { "enum": ["growth_rate", "cagr", "margin", "ratio", "difference", "share_of_total", "per_share", "other"] },
        "input_metric_ids": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/metricId" } },
        "output_expectation": {
          "type": "object",
          "additionalProperties": false,
          "required": ["unit", "currency", "period", "as_of_date"],
          "properties": {
            "unit": { "type": "string", "minLength": 1 },
            "currency": { "oneOf": [{ "type": "string" }, { "type": "null" }] },
            "period": { "type": "string" },
            "as_of_date": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" }
          }
        },
        "needed_for": { "type": "string", "minLength": 1 },
        "formula_hint": { "type": "string", "description": "Non-executable human-readable description ONLY. The deterministic calc service selects its own implementation from calculation_type + input_metric_ids and must never parse or execute this string." },
        "status": { "type": "string" }
      }
    },

    "s1_output": {
      "type": "object",
      "unevaluatedProperties": false,
      "allOf": [{ "$ref": "#/$defs/annotations" }],
      "required": ["candidate_metrics", "candidate_claims", "extraction_gaps"],
      "properties": {
        "candidate_metrics": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["candidate_id", "name_verbatim", "value", "unit", "currency", "period", "as_of_date", "source_id", "source_url_or_document", "retrieved_at", "quote", "unit_conversion_note"],
            "properties": {
              "candidate_id": { "type": "string", "pattern": "^CMET-[0-9]{3}$" },
              "name_verbatim": { "type": "string", "minLength": 1 },
              "value": { "type": "number" },
              "unit": { "type": "string", "minLength": 1 },
              "currency": { "oneOf": [{ "type": "string" }, { "type": "null" }] },
              "period": { "type": "string", "minLength": 1 },
              "as_of_date": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
              "source_id": { "$ref": "#/$defs/sourceId" },
              "source_url_or_document": { "type": "string", "minLength": 1 },
              "retrieved_at": { "type": "string", "minLength": 1 },
              "quote": { "type": "string", "minLength": 1 },
              "unit_conversion_note": { "type": "string", "minLength": 1 }
            }
          }
        },
        "candidate_claims": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["candidate_id", "type", "text_original_language", "source_ids", "quote"],
            "properties": {
              "candidate_id": { "type": "string", "pattern": "^CCLM-[0-9]{3}$" },
              "type": { "const": "fact" },
              "text_original_language": { "type": "string", "minLength": 1 },
              "source_ids": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/sourceId" } },
              "quote": { "type": "string", "minLength": 1 }
            }
          }
        },
        "extraction_gaps": { "type": "array", "items": { "type": "string" } }
      }
    },

    "s2_output": {
      "type": "object",
      "unevaluatedProperties": false,
      "allOf": [{ "$ref": "#/$defs/annotations" }],
      "required": ["verdicts", "unverifiable_entities"],
      "properties": {
        "verdicts": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["candidate_id", "verdict", "checks", "reasons"],
            "properties": {
              "candidate_id": { "type": "string", "pattern": "^(CMET|CCLM)-[0-9]{3}$" },
              "verdict": { "enum": ["verified", "rejected", "needs_review"] },
              "checks": {
                "type": "object",
                "additionalProperties": false,
                "required": ["quote_found", "value_matches_quote", "source_tier_sufficient", "date_fresh", "entity_known"],
                "properties": {
                  "quote_found": { "type": "boolean" },
                  "value_matches_quote": { "type": "boolean" },
                  "source_tier_sufficient": { "type": "boolean" },
                  "date_fresh": { "type": "boolean" },
                  "entity_known": { "type": "boolean" }
                }
              },
              "reasons": { "type": "array", "items": { "type": "string" } }
            },
            "allOf": [
              { "if": { "properties": { "verdict": { "const": "verified" } } },
                "then": { "properties": { "checks": { "properties": {
                  "quote_found": { "const": true }, "value_matches_quote": { "const": true },
                  "source_tier_sufficient": { "const": true }, "date_fresh": { "const": true },
                  "entity_known": { "const": true } } } } } },
              { "if": { "properties": { "verdict": { "enum": ["rejected", "needs_review"] } } },
                "then": { "properties": { "reasons": { "minItems": 1 } } } }
            ]
          }
        },
        "unverifiable_entities": { "type": "array", "items": { "type": "string" } }
      }
    },

    "s3_output": {
      "type": "object",
      "unevaluatedProperties": false,
      "allOf": [{ "$ref": "#/$defs/annotations" }],
      "required": ["claims", "section_assignment", "insufficient"],
      "properties": {
        "claims": { "type": "array", "items": { "$ref": "#/$defs/claimFragment" } },
        "section_assignment": {
          "type": "object",
          "additionalProperties": { "type": "array", "items": { "$ref": "#/$defs/claimId" } }
        },
        "value_chain_nodes": {
          "type": "array", "minItems": 3, "maxItems": 6,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["position", "name_authored"],
            "properties": {
              "position": { "enum": ["upstream", "midstream", "downstream"] },
              "name_authored": { "type": "string", "minLength": 1 },
              "claim_id": { "oneOf": [{ "$ref": "#/$defs/claimId" }, { "type": "null" }] },
              "metric_id": { "oneOf": [{ "$ref": "#/$defs/metricId" }, { "type": "null" }] },
              "highlight": { "type": "boolean" }
            }
          }
        },
        "market_specific_claims": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "cn_policy_context": { "type": "array", "items": { "$ref": "#/$defs/claimId" } },
            "us_filing_context": { "type": "array", "items": { "$ref": "#/$defs/claimId" } }
          }
        },
        "comparison_entities": {
          "type": "array", "minItems": 1, "maxItems": 4,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["entity_authored", "metric_ids", "claim_ids", "limited_data"],
            "properties": {
              "entity_authored": { "type": "string", "minLength": 1 },
              "metric_ids": { "type": "array", "items": { "$ref": "#/$defs/metricId" } },
              "claim_ids": { "type": "array", "items": { "$ref": "#/$defs/claimId" } },
              "limited_data": { "type": "boolean" }
            }
          }
        },
        "moat_assessment": {
          "type": "object",
          "additionalProperties": false,
          "required": ["claim_id", "durability"],
          "properties": {
            "claim_id": { "$ref": "#/$defs/claimId" },
            "durability": { "enum": ["weak", "moderate", "strong"] }
          }
        },
        "requested_calculations": { "type": "array", "items": { "$ref": "#/$defs/requestedCalculation" } },
        "insufficient": { "type": "array", "items": { "type": "string" } }
      }
    },

    "s4_output": {
      "type": "object",
      "unevaluatedProperties": false,
      "allOf": [{ "$ref": "#/$defs/annotations" }],
      "required": ["assumption_rationales", "scenario_narratives", "rating", "rating_claim_id", "counterevidence_claim_ids", "claims", "insufficient"],
      "properties": {
        "assumption_rationales": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["assumption_id", "rationale_claim_id"],
            "properties": {
              "assumption_id": { "$ref": "#/$defs/assumptionId" },
              "rationale_claim_id": { "$ref": "#/$defs/claimId" }
            }
          }
        },
        "scenario_narratives": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "bull": { "$ref": "#/$defs/claimId" },
            "base": { "$ref": "#/$defs/claimId" },
            "bear": { "$ref": "#/$defs/claimId" }
          }
        },
        "rating": { "enum": ["buy", "accumulate", "hold", "reduce", "sell", "not_rated"] },
        "rating_claim_id": { "$ref": "#/$defs/claimId" },
        "counterevidence_claim_ids": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/claimId" } },
        "claims": { "type": "array", "items": { "$ref": "#/$defs/claimFragment" } },
        "insufficient": { "type": "array", "items": { "type": "string" } }
      }
    },

    "s5_output": {
      "type": "object",
      "unevaluatedProperties": false,
      "allOf": [{ "$ref": "#/$defs/annotations" }],
      "required": ["catalysts", "risks", "supporting_claims"],
      "properties": {
        "catalysts": {
          "type": "array",
          "items": { "$ref": "https://jacaranda.example/schemas/research-package.schema.json#/properties/catalysts/items" }
        },
        "risks": {
          "type": "array", "minItems": 3,
          "items": { "$ref": "https://jacaranda.example/schemas/research-package.schema.json#/properties/risks/items" }
        },
        "supporting_claims": { "type": "array", "items": { "$ref": "#/$defs/claimFragment" } },
        "notes": { "type": "string" }
      }
    },

    "s6_output": {
      "type": "object",
      "unevaluatedProperties": false,
      "allOf": [{ "$ref": "#/$defs/annotations" }],
      "required": ["authoritative_language", "texts", "translation_flags", "glossary_flags"],
      "properties": {
        "authoritative_language": { "enum": ["zh_CN", "en_AU"] },
        "texts": {
          "type": "array", "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "zh_CN", "en_AU"],
            "properties": {
              "path": { "type": "string", "minLength": 1 },
              "zh_CN": { "type": "string", "minLength": 1 },
              "en_AU": { "type": "string", "minLength": 1 }
            }
          }
        },
        "translation_flags": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "problem"],
            "properties": { "path": { "type": "string" }, "problem": { "type": "string" } }
          }
        },
        "glossary_flags": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["term", "path", "proposed_mapping"],
            "properties": { "term": { "type": "string" }, "path": { "type": "string" }, "proposed_mapping": { "type": "string" } }
          }
        }
      }
    }
  }
}
